<!DOCTYPE html>
<html lang="ja">
<head>
  <title><%= content_for(:title) || "Admin Login" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
<% flash.each do |key, message| %>
  <div class="mx-auto mt-4 max-w-md rounded-lg border p-4 text-sm <%= key == "notice" ? "border-green-200 bg-green-50 text-green-800" : "border-red-200 bg-red-50 text-red-800" %>" role="alert">
    <%= message %>
  </div>
<% end %>
<%= yield %>
</body>
</html>

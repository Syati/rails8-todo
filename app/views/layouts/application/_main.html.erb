<main class="flex-1 px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <% flash.each do |key, message| %>
      <div class="mb-4 rounded-lg border p-4 text-sm <%= key == "notice" ? "border-green-200 bg-green-50 text-green-800" : "border-red-200 bg-red-50 text-red-800" %>" role="alert">
        <%= message %>
      </div>
    <% end %>

    <%= yield %>
  </div>
</main>

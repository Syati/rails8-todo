<div class="mx-auto flex min-h-screen w-full max-w-md flex-col justify-center px-4 py-8">
  <div class="mb-6 text-center text-2xl font-semibold text-gray-900">
    <span class="font-bold">Rails8</span> Todo
  </div>

  <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-200 px-6 py-4 text-center">
      <h2 class="text-xl font-semibold text-gray-900"><%= t(".sign_up") %></h2>
    </div>
    <div class="p-6">
      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= f.error_notification %>

        <div class="mb-4">
          <%= f.input_field :email,
                           autofocus: true,
                           autocomplete: "email",
                           class: "block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-500 focus:ring-blue-500",
                           placeholder: "Email" %>
        </div>

        <div class="mb-4">
          <%= f.input_field :password,
                           autocomplete: "new-password",
                           class: "block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-500 focus:ring-blue-500",
                           placeholder: "Password" %>
        </div>
        <% if @minimum_password_length %>
          <p class="mb-4 text-sm text-gray-500"><%= t('devise.shared.minimum_password_length', count: @minimum_password_length) %></p>
        <% end %>

        <div class="mb-4">
          <%= f.input_field :password_confirmation,
                           autocomplete: "new-password",
                           class: "block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-500 focus:ring-blue-500",
                           placeholder: "Password confirmation" %>
        </div>

        <%= f.button :submit, t(".sign_up"), class: "w-full rounded-lg bg-blue-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-800 focus:outline-none focus:ring-4 focus:ring-blue-300" %>
      <% end %>

      <div class="mt-6 text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>

<div class="mt-3 space-y-2">
  <%- if controller_name != 'sessions' %>
    <%= link_to t(".sign_in"), new_session_path(resource_name), class: "block w-full rounded-lg px-4 py-2 text-center text-sm font-medium text-blue-700 hover:bg-blue-50" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to t(".sign_up"), new_registration_path(resource_name), class: "block w-full rounded-lg px-4 py-2 text-center text-sm font-medium text-blue-700 hover:bg-blue-50" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to t(".forgot_your_password"), new_password_path(resource_name), class: "block w-full rounded-lg px-4 py-2 text-center text-sm font-medium text-blue-700 hover:bg-blue-50" %>
  <% end %>
  <%= link_to t('.faq'), faq_path, class: "block w-full rounded-lg px-4 py-2 text-center text-sm font-medium text-blue-700 hover:bg-blue-50" %>
</div>

<div class="mx-auto flex min-h-screen w-full max-w-md flex-col justify-center px-4 py-8">
  <div class="mb-6 text-center text-2xl font-semibold text-gray-900">
    <span class="font-bold">Rails8</span> Todo
  </div>

  <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-200 px-6 py-4 text-center">
      <h2 class="text-xl font-semibold text-gray-900"><%= t(".resend_unlock_instructions") %></h2>
    </div>
    <div class="p-6">
      <%= simple_form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post }) do |f| %>
        <%= f.error_notification %>
        <%= f.full_error :unlock_token %>

        <div class="mb-4">
          <%= f.input_field :email,
                           autofocus: true,
                           autocomplete: "email",
                           class: "block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-500 focus:ring-blue-500",
                           placeholder: "Email" %>
        </div>

        <%= f.button :submit, t(".resend_unlock_instructions"), class: "w-full rounded-lg bg-blue-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-800 focus:outline-none focus:ring-4 focus:ring-blue-300" %>
      <% end %>

      <div class="mt-6 text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>

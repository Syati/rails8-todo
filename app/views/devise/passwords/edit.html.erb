<div class="login-box">
  <div class="login-logo">
    <b>Rails8</b> Todo
  </div>

  <div class="card card-outline card-primary">
    <div class="card-header text-center">
      <h2 class="mb-0"><%= t(".change_your_password") %></h2>
    </div>
    <div class="card-body login-card-body">
      <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= f.error_notification %>
        <%= f.input :reset_password_token, as: :hidden %>
        <%= f.full_error :reset_password_token %>

        <div class="input-group mb-3">
          <%= f.input_field :password,
                           autofocus: true,
                           autocomplete: "new-password",
                           class: "form-control",
                           placeholder: "New password" %>
          <div class="input-group-text">
            <i class="bi bi-lock"></i>
          </div>
        </div>
        <% if @minimum_password_length %>
          <p class="text-muted small mb-3"><%= t('devise.shared.minimum_password_length', count: @minimum_password_length) %></p>
        <% end %>

        <div class="input-group mb-3">
          <%= f.input_field :password_confirmation,
                           autocomplete: "new-password",
                           class: "form-control",
                           placeholder: "Confirm new password" %>
          <div class="input-group-text">
            <i class="bi bi-lock-fill"></i>
          </div>
        </div>

        <div class="row">
          <div class="col-12">
            <%= f.button :submit, t(".change_my_password"), class: "btn btn-primary w-100" %>
          </div>
        </div>
      <% end %>

      <div class="mt-3 text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>

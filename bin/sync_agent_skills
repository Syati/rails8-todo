#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "yaml"

ROOT_DIR = File.expand_path("..", __dir__)
SOURCE_DIR = File.join(ROOT_DIR, ".github", "agents")
DEST_DIR = File.join(ROOT_DIR, ".agents", "skills")

check_only = false
source_dir = SOURCE_DIR
dest_dir = DEST_DIR

until ARGV.empty?
  arg = ARGV.shift
  case arg
  when "--check"
    check_only = true
  when "--source"
    value = ARGV.shift
    abort "--source にはパス指定が必要です" if value.nil?
    source_dir = File.expand_path(value, ROOT_DIR)
  when "--dest"
    value = ARGV.shift
    abort "--dest にはパス指定が必要です" if value.nil?
    dest_dir = File.expand_path(value, ROOT_DIR)
  else
    abort "unknown argument: #{arg}"
  end
end

def parse_agent_file(path)
  content = File.read(path)
  match = content.match(/\A---\s*\n(.*?)\n---\s*\n/m)
  raise "#{path}: frontmatter が見つかりません" unless match

  frontmatter = YAML.safe_load(match[1], permitted_classes: [], aliases: false) || {}
  body = content[match[0].length..]
  [frontmatter, body]
end

def render_skill(name, description, source_basename, body)
  <<~SKILL
    ---
    name: #{name}
    description: #{description}
    ---

    # Source

    - `.github/agents/#{source_basename}`

    #{body.to_s.rstrip}
  SKILL
end

agent_files = Dir.glob(File.join(source_dir, "*.md")).sort
abort "source files not found: #{source_dir}/*.md" if agent_files.empty?

changed = false
FileUtils.mkdir_p(dest_dir) unless check_only

agent_files.each do |agent_file|
  frontmatter, body = parse_agent_file(agent_file)
  name = frontmatter["name"] || File.basename(agent_file, ".md")
  description = frontmatter["description"] || "#{name} skill"
  skill_dir = File.join(dest_dir, name)
  target_file = File.join(skill_dir, "SKILL.md")
  rendered = render_skill(name, description, File.basename(agent_file), body)

  current = File.exist?(target_file) ? File.read(target_file) : nil
  next if current == rendered

  changed = true
  if check_only
    puts "needs update: #{target_file}"
    next
  end

  FileUtils.mkdir_p(skill_dir)
  File.write(target_file, rendered)
  puts "updated: #{target_file}"
end

if check_only
  if changed
    puts "agent skills are not in sync"
    exit 1
  end

  puts "agent skills are in sync"
end
